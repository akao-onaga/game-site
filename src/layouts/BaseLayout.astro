---
import "../styles/global.css";
import PixelChara from "../components/PixelChara.astro";

interface Props {
  title?: string;
  description?: string;
  /** OGP用の画像(絶対URL、またはpublic/からのパス) */
  image?: string;
  lang?: "ja" | "en";
  alternateHref?: string;
}

const xUrl = "https://x.com/akaogame0124";
// Cloudflareダッシュボード > Web Analytics でサイト登録後、発行されたトークンを設定する
// 空のままだと計測スクリプトは出力されない
const cfAnalyticsToken = "362b6cd98b3c466699db4f607779ffdc";
const {
  title,
  image = "/ogp.png",
  lang = "ja",
  alternateHref: providedAlternateHref,
} = Astro.props;

const isEnglish = lang === "en";
const copy = isEnglish
  ? {
      siteName: "Akao Game Development",
      description:
        "Games by indie developer Akao, including the unityroom 100-Game Project.",
      unityroom: "100 Games",
      ios: "iOS Games",
      about: "About",
      updates: "Follow the latest releases on",
      privacy: "Privacy Policy",
      language: "日本語",
      languageLabel: "View this page in Japanese",
    }
  : {
      siteName: "あかお＠ゲーム開発",
      description:
        "個人ゲーム開発者「あかお」の作品紹介サイト。unityroom 100本投稿企画に挑戦中!",
      unityroom: "100本企画",
      ios: "iOSアプリ",
      about: "開発者",
      updates: "最新情報は",
      privacy: "プライバシーポリシー",
      language: "EN",
      languageLabel: "View this page in English",
    };

const description = Astro.props.description ?? copy.description;
const siteName = copy.siteName;
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const currentPath = Astro.url.pathname;
const shouldDetectLanguage = currentPath === "/" && !isEnglish;
const alternateHref =
  providedAlternateHref ??
  (isEnglish
    ? currentPath.replace(/^\/en(?=\/|$)/, "") || "/"
    : currentPath === "/"
      ? "/en/"
      : `/en${currentPath}`);
const japaneseHref = isEnglish ? alternateHref : currentPath;
const englishHref = isEnglish ? currentPath : alternateHref;
const absoluteUrl = (path: string) =>
  Astro.site ? new URL(path, Astro.site).href : undefined;
const canonicalUrl = absoluteUrl(currentPath);
const japaneseUrl = absoluteUrl(japaneseHref);
const englishUrl = absoluteUrl(englishHref);

// 相対パスの画像は site 設定(astro.config.mjs)があるときだけ絶対URL化できる
const ogImage = image
  ? image.startsWith("http")
    ? image
    : Astro.site
      ? new URL(image, Astro.site).href
      : undefined
  : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {japaneseUrl && <link rel="alternate" hreflang="ja" href={japaneseUrl} />}
    {englishUrl && <link rel="alternate" hreflang="en" href={englishUrl} />}
    {japaneseUrl && <link rel="alternate" hreflang="x-default" href={japaneseUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={isEnglish ? "en_US" : "ja_JP"} />
    <meta
      property="og:locale:alternate"
      content={isEnglish ? "ja_JP" : "en_US"}
    />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DotGothic16&display=swap"
      rel="stylesheet"
    />
    {
      shouldDetectLanguage && (
        <script is:inline>
          (() => {
            const savedLanguage = document.cookie
              .split("; ")
              .find((entry) => entry.startsWith("akao_language="))
              ?.split("=")[1];

            if (savedLanguage === "ja") return;
            if (
              savedLanguage !== "en" &&
              /bot|crawler|spider|crawling/i.test(navigator.userAgent)
            ) {
              return;
            }

            const preferredLanguage =
              savedLanguage === "en"
                ? "en"
                : (navigator.languages?.[0] ?? navigator.language);

            if (preferredLanguage?.toLowerCase().startsWith("en")) {
              window.location.replace(
                `/en/${window.location.search}${window.location.hash}`,
              );
            }
          })();
        </script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="site-logo" href={isEnglish ? "/en/" : "/"}>
          <PixelChara size={22} />
          {siteName}
        </a>
        <nav class="site-nav">
          <a href={isEnglish ? "/en/#unityroom" : "/#unityroom"}>
            {copy.unityroom}
          </a>
          <a href={isEnglish ? "/en/#ios" : "/#ios"}>{copy.ios}</a>
          <a href={isEnglish ? "/en/about/" : "/about/"}>{copy.about}</a>
          <a
            class="lang-switch"
            href={alternateHref}
            hreflang={isEnglish ? "ja" : "en"}
            aria-label={copy.languageLabel}
            data-language-choice={isEnglish ? "ja" : "en"}
          >
            {copy.language}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          {copy.updates}
          {" "}
          <a href={xUrl} target="_blank" rel="noopener">X (Twitter)</a>
          {!isEnglish && " で発信中"}
        </p>
        <p style="margin: 4px 0 12px;">
          <a href={isEnglish ? "/en/privacy/" : "/privacy/"}>{copy.privacy}</a>
        </p>
        © {new Date().getFullYear()} {siteName}
      </div>
    </footer>
    {
      cfAnalyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}
        />
      )
    }
    <script is:inline>
      document
        .querySelector("[data-language-choice]")
        ?.addEventListener("click", (event) => {
          const language = event.currentTarget.dataset.languageChoice;
          document.cookie = `akao_language=${language}; Path=/; Max-Age=31536000; SameSite=Lax`;
        });
    </script>
  </body>
</html>
