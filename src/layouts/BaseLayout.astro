---
import "../styles/global.css";
import PixelChara from "../components/PixelChara.astro";
import {
  defaultLocale,
  getLocalizedPath,
  localeCodes,
  localeMeta,
  type Locale,
} from "../i18n/config";
import { uiCopy } from "../i18n/ui";

interface Props {
  title?: string;
  description?: string;
  /** OGP用の画像(絶対URL、またはpublic/からのパス) */
  image?: string;
  locale?: Locale;
}

const xUrl = "https://x.com/akaogame0124";
// Cloudflareダッシュボード > Web Analytics でサイト登録後、発行されたトークンを設定する
// 空のままだと計測スクリプトは出力されない
const cfAnalyticsToken = "362b6cd98b3c466699db4f607779ffdc";
const {
  title,
  image = "/ogp.png",
  locale = defaultLocale,
} = Astro.props;

const copy = uiCopy[locale].layout;
const meta = localeMeta[locale];
const description = Astro.props.description ?? copy.description;
const siteName = copy.siteName;
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const currentPath = Astro.url.pathname;
const shouldDetectLanguage =
  currentPath === "/" && locale === defaultLocale;
const absoluteUrl = (path: string) =>
  Astro.site ? new URL(path, Astro.site).href : undefined;
const canonicalUrl = absoluteUrl(currentPath);
const alternateLinks = localeCodes.map((targetLocale) => ({
  locale: targetLocale,
  label: localeMeta[targetLocale].label,
  hreflang: localeMeta[targetLocale].hreflang,
  href: getLocalizedPath(currentPath, targetLocale),
  absoluteHref: absoluteUrl(getLocalizedPath(currentPath, targetLocale)),
}));
const defaultUrl = absoluteUrl(
  getLocalizedPath(currentPath, defaultLocale),
);

// 相対パスの画像は site 設定(astro.config.mjs)があるときだけ絶対URL化できる
const ogImage = image
  ? image.startsWith("http")
    ? image
    : Astro.site
      ? new URL(image, Astro.site).href
      : undefined
  : undefined;
---

<!doctype html>
<html lang={meta.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {
      alternateLinks.map(
        (link) =>
          link.absoluteHref && (
            <link
              rel="alternate"
              hreflang={link.hreflang}
              href={link.absoluteHref}
            />
          ),
      )
    }
    {defaultUrl && <link rel="alternate" hreflang="x-default" href={defaultUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={meta.ogLocale} />
    {
      localeCodes
        .filter((targetLocale) => targetLocale !== locale)
        .map((targetLocale) => (
          <meta
            property="og:locale:alternate"
            content={localeMeta[targetLocale].ogLocale}
          />
        ))
    }
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DotGothic16&display=swap"
      rel="stylesheet"
    />
    {
      shouldDetectLanguage && (
        <script is:inline>
          (() => {
            const supportedLocales = [
              "ja",
              "en",
              "zh-cn",
              "zh-tw",
              "ko",
              "es",
              "fr",
              "de",
              "pt-br",
            ];
            const savedValue = document.cookie
              .split("; ")
              .find((entry) => entry.startsWith("akao_language="))
              ?.split("=")[1];
            const savedLanguage = supportedLocales.includes(savedValue)
              ? savedValue
              : null;

            if (savedLanguage === "ja") return;
            if (
              savedLanguage !== "en" &&
              /bot|crawler|spider|crawling/i.test(navigator.userAgent)
            ) {
              return;
            }

            const detectLocale = (language) => {
              const normalized = language?.toLowerCase() ?? "";
              if (normalized.startsWith("zh")) {
                return /(?:hant|tw|hk|mo)/.test(normalized)
                  ? "zh-tw"
                  : "zh-cn";
              }
              if (normalized.startsWith("ko")) return "ko";
              if (normalized.startsWith("es")) return "es";
              if (normalized.startsWith("fr")) return "fr";
              if (normalized.startsWith("de")) return "de";
              if (normalized.startsWith("pt")) return "pt-br";
              if (normalized.startsWith("ja")) return "ja";
              return "en";
            };

            const targetLocale =
              savedLanguage ??
              detectLocale(navigator.languages?.[0] ?? navigator.language);

            if (targetLocale !== "ja") {
              window.location.replace(
                `/${targetLocale}/${window.location.search}${window.location.hash}`,
              );
            }
          })();
        </script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="site-logo" href={getLocalizedPath("/", locale)}>
          <PixelChara size={22} />
          {siteName}
        </a>
        <nav class="site-nav">
          <a href={`${getLocalizedPath("/", locale)}#unityroom`}>
            {copy.unityroom}
          </a>
          <a href={`${getLocalizedPath("/", locale)}#ios`}>{copy.ios}</a>
          <a href={getLocalizedPath("/about/", locale)}>{copy.about}</a>
          <label class="language-select">
            <span class="sr-only">{copy.languageLabel}</span>
            <select aria-label={copy.languageLabel} data-language-select>
              {
                alternateLinks.map((link) => (
                  <option
                    value={link.href}
                    data-language-code={link.locale}
                    selected={link.locale === locale}
                  >
                    {link.label}
                  </option>
                ))
              }
            </select>
          </label>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          {copy.updatesBefore}
          {" "}
          <a href={xUrl} target="_blank" rel="noopener">X (Twitter)</a>
          {copy.updatesAfter && ` ${copy.updatesAfter}`}
        </p>
        <p style="margin: 4px 0 12px;">
          <a href={getLocalizedPath("/privacy/", locale)}>{copy.privacy}</a>
        </p>
        © {new Date().getFullYear()} {siteName}
      </div>
    </footer>
    {
      cfAnalyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}
        />
      )
    }
    <script is:inline>
      document
        .querySelector("[data-language-select]")
        ?.addEventListener("change", (event) => {
          const selectedOption = event.currentTarget.selectedOptions[0];
          const language = selectedOption.dataset.languageCode;
          document.cookie = `akao_language=${language}; Path=/; Max-Age=31536000; SameSite=Lax`;
          window.location.assign(event.currentTarget.value);
        });
    </script>
  </body>
</html>
