---
import LocalizedPrivacy from "../../components/LocalizedPrivacy.astro";
import {
  additionalLocales,
  type AdditionalLocale,
} from "../../i18n/config";

export function getStaticPaths() {
  return additionalLocales.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: AdditionalLocale };
---

<LocalizedPrivacy locale={locale} />
