---
import BaseLayout from "../layouts/BaseLayout.astro";
import PixelChara from "../components/PixelChara.astro";
---

<BaseLayout title="ページが見つかりません">
  <section class="section" style="text-align: center; padding-bottom: 96px;">
    <div class="container">
      <p
        style="font-size: clamp(3rem, 10vw, 5rem); font-weight: 700; margin: 24px 0 0;"
      >
        404
      </p>
      <div style="display: flex; justify-content: center; padding: 8px 0 24px;">
        <PixelChara size={64} />
      </div>
      <p>お探しのページは見つかりませんでした。</p>
      <p>
        <a class="back-link" href="/">← トップページへもどる</a>
      </p>
    </div>
  </section>
</BaseLayout>
