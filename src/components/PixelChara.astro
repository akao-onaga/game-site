---
// アイコン画像のキャラクター「あかお」のピクセルアートSVG(26x31グリッド)
interface Props {
  size?: number;
}
const { size = 64 } = Astro.props;
---

<svg
  width={size}
  height={size * (31 / 26)}
  viewBox="0 0 26 31"
  shape-rendering="crispEdges"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- 頭(髪+輪郭) -->
  <rect x="5" y="0" width="16" height="1" fill="#16161c"></rect>
  <rect x="4" y="1" width="18" height="13" fill="#16161c"></rect>
  <rect x="6" y="2" width="5" height="1" fill="#34343f"></rect>
  <!-- 顔 -->
  <rect x="5" y="5" width="16" height="8" fill="#f7e08a"></rect>
  <rect x="5" y="5" width="2" height="2" fill="#16161c"></rect>
  <rect x="19" y="5" width="2" height="2" fill="#16161c"></rect>
  <rect x="5" y="12" width="16" height="1" fill="#e9d07c"></rect>
  <!-- 目(ハイライト付き) -->
  <rect x="9" y="8" width="2" height="2" fill="#16161c"></rect>
  <rect x="15" y="8" width="2" height="2" fill="#16161c"></rect>
  <rect x="9" y="8" width="1" height="1" fill="#ffffff"></rect>
  <rect x="15" y="8" width="1" height="1" fill="#ffffff"></rect>
  <!-- ほっぺ -->
  <rect x="6" y="11" width="2" height="1" fill="#f5b8c4"></rect>
  <rect x="18" y="11" width="2" height="1" fill="#f5b8c4"></rect>
  <!-- 腕+胴の輪郭 -->
  <rect x="1" y="13" width="24" height="1" fill="#16161c"></rect>
  <rect x="0" y="14" width="26" height="6" fill="#16161c"></rect>
  <rect x="1" y="20" width="24" height="1" fill="#16161c"></rect>
  <!-- 腕 -->
  <rect x="1" y="14" width="4" height="4" fill="#35a3e0"></rect>
  <rect x="21" y="14" width="4" height="4" fill="#35a3e0"></rect>
  <rect x="1" y="17" width="4" height="1" fill="#2b8ac2"></rect>
  <rect x="21" y="17" width="4" height="1" fill="#2b8ac2"></rect>
  <!-- 手 -->
  <rect x="1" y="18" width="3" height="2" fill="#f7e08a"></rect>
  <rect x="22" y="18" width="3" height="2" fill="#f7e08a"></rect>
  <!-- 胴(シャツ) -->
  <rect x="5" y="14" width="16" height="6" fill="#2456a8"></rect>
  <rect x="5" y="16" width="16" height="2" fill="#35a3e0"></rect>
  <rect x="5" y="19" width="16" height="1" fill="#1c4488"></rect>
  <!-- ズボン -->
  <rect x="4" y="20" width="18" height="4" fill="#16161c"></rect>
  <rect x="5" y="21" width="16" height="2" fill="#262633"></rect>
  <!-- 足 -->
  <rect x="6" y="23" width="5" height="7" fill="#16161c"></rect>
  <rect x="15" y="23" width="5" height="7" fill="#16161c"></rect>
  <rect x="7" y="24" width="3" height="4" fill="#262633"></rect>
  <rect x="16" y="24" width="3" height="4" fill="#262633"></rect>
</svg>
