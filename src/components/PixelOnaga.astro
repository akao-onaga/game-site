---
// 相棒のシマエナガ「おナガ」のピクセルアートSVG(22x22グリッド)
interface Props {
  size?: number;
}
const { size = 48 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 22 22"
  shape-rendering="crispEdges"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- まんまるな体の輪郭 -->
  <rect x="7" y="0" width="8" height="1" fill="#16161c"></rect>
  <rect x="5" y="1" width="12" height="1" fill="#16161c"></rect>
  <rect x="3" y="2" width="16" height="1" fill="#16161c"></rect>
  <rect x="2" y="3" width="18" height="2" fill="#16161c"></rect>
  <rect x="1" y="5" width="20" height="10" fill="#16161c"></rect>
  <rect x="2" y="15" width="18" height="2" fill="#16161c"></rect>
  <rect x="3" y="17" width="16" height="1" fill="#16161c"></rect>
  <rect x="5" y="18" width="12" height="1" fill="#16161c"></rect>
  <rect x="7" y="19" width="8" height="1" fill="#16161c"></rect>
  <!-- 体の白いもふもふ -->
  <rect x="7" y="1" width="8" height="1" fill="#ffffff"></rect>
  <rect x="5" y="2" width="12" height="1" fill="#ffffff"></rect>
  <rect x="3" y="3" width="16" height="2" fill="#ffffff"></rect>
  <rect x="2" y="5" width="18" height="10" fill="#ffffff"></rect>
  <rect x="3" y="15" width="16" height="2" fill="#ffffff"></rect>
  <rect x="5" y="17" width="12" height="1" fill="#ffffff"></rect>
  <rect x="7" y="18" width="8" height="1" fill="#ffffff"></rect>
  <!-- おなかの羽毛(ごく淡い陰影) -->
  <rect x="5" y="15" width="12" height="2" fill="#f4efe4"></rect>
  <rect x="7" y="17" width="8" height="1" fill="#f4efe4"></rect>
  <!-- つぶらな目 -->
  <rect x="7" y="8" width="2" height="2" fill="#16161c"></rect>
  <rect x="13" y="8" width="2" height="2" fill="#16161c"></rect>
  <!-- ちいさなくちばし -->
  <rect x="10" y="10" width="2" height="1" fill="#e0993c"></rect>
  <!-- ほっぺ -->
  <rect x="5" y="11" width="2" height="1" fill="#ffd4dc"></rect>
  <rect x="15" y="11" width="2" height="1" fill="#ffd4dc"></rect>
  <!-- ちいさな羽(やわらかいベージュ) -->
  <rect x="3" y="11" width="2" height="4" fill="#d9c0a8"></rect>
  <rect x="17" y="11" width="2" height="4" fill="#d9c0a8"></rect>
  <!-- ちいさな足 -->
  <rect x="8" y="20" width="2" height="2" fill="#16161c"></rect>
  <rect x="12" y="20" width="2" height="2" fill="#16161c"></rect>
</svg>
