---
import type { CollectionEntry } from "astro:content";
import { getLocalePrefix, type Locale } from "../i18n/config";
import type { GameTranslation } from "../i18n/game";

interface Props {
  game: CollectionEntry<"games"> | CollectionEntry<"gamesEn">;
  locale?: Locale;
  translation?: GameTranslation;
}

const { game, locale = "ja", translation } = Astro.props;
const view = translation ?? game.data;
const href = `${getLocalePrefix(locale)}/games/${game.id}/`;
const imageAlt =
  locale === "ja"
    ? `${view.title}のカバー画像`
    : `${view.title} cover art`;
---

<a class="game-card" href={href}>
  <img src={game.data.cover} alt={imageAlt} loading="lazy" />
  <div class="game-card-body">
    <h3>{view.title}</h3>
    <p class="catch">{view.catch}</p>
    <div class="badges">
      {
        game.data.unityroomNo && (
          <span class="badge badge-no">
            {locale === "ja"
              ? `${game.data.unityroomNo}本目`
              : `#${game.data.unityroomNo}`}
          </span>
        )
      }
      <span class="badge">{view.genre}</span>
      {game.data.platforms.map((p) => <span class="badge">{p}</span>)}
    </div>
  </div>
</a>
