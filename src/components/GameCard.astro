---
import type { CollectionEntry } from "astro:content";

interface Props {
  game: CollectionEntry<"games"> | CollectionEntry<"gamesEn">;
  lang?: "ja" | "en";
}

const { game, lang = "ja" } = Astro.props;
const isEnglish = lang === "en";
const href = `${isEnglish ? "/en" : ""}/games/${game.id}/`;
const imageAlt = isEnglish
  ? `${game.data.title} cover art`
  : `${game.data.title}のカバー画像`;
---

<a class="game-card" href={href}>
  <img src={game.data.cover} alt={imageAlt} loading="lazy" />
  <div class="game-card-body">
    <h3>{game.data.title}</h3>
    <p class="catch">{game.data.catch}</p>
    <div class="badges">
      {
        game.data.unityroomNo && (
          <span class="badge badge-no">
            {isEnglish ? `#${game.data.unityroomNo}` : `${game.data.unityroomNo}本目`}
          </span>
        )
      }
      <span class="badge">{game.data.genre}</span>
      {game.data.platforms.map((p) => <span class="badge">{p}</span>)}
    </div>
  </div>
</a>
