---
import { render, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Dialogue from "./Dialogue.astro";
import {
  getLocalePrefix,
  localeMeta,
  type Locale,
} from "../i18n/config";
import type { GameTranslation } from "../i18n/game";
import { uiCopy } from "../i18n/ui";

interface Props {
  game: CollectionEntry<"games"> | CollectionEntry<"gamesEn">;
  locale?: Locale;
  translation?: GameTranslation;
}

const { game, locale = "ja", translation } = Astro.props;
const { Content } = await render(game);
const copy = uiCopy[locale].game;
const view = translation ?? game.data;
const releaseLabel = game.data.releaseDate.toLocaleDateString(
  localeMeta[locale].dateLocale,
  {
    year: "numeric",
    month: "long",
    day: "numeric",
  },
);
const localeBase = getLocalePrefix(locale);
const gameListHref =
  game.data.category === "ios"
    ? `${localeBase}/#ios`
    : `${localeBase}/#unityroom`;
const heroIcon = game.data.icon ?? game.data.cover;
const appIconAlt =
  locale === "ja"
    ? `${view.title}の${copy.appIcon}`
    : `${view.title} ${copy.appIcon}`;
const mainImageAlt =
  locale === "ja"
    ? `${view.title}の${copy.mainImage}`
    : `${view.title} ${copy.mainImage}`;
const screenshotAlt = (index: number) =>
  locale === "ja"
    ? `${view.title}の${copy.screenshot}${index + 1}`
    : `${view.title} ${copy.screenshot} ${index + 1}`;
const externalLinks = game.data.links.map((link) => {
  if (game.data.category === "ios") {
    const appId = link.url.match(/id(\d+)/)?.[1];
    return {
      label: copy.viewAppStore,
      url: appId ? `https://apps.apple.com/app/id${appId}` : link.url,
    };
  }

  return { label: copy.playUnityroom, url: link.url };
});
---

<BaseLayout
  title={view.title}
  description={view.catch}
  image={game.data.cover}
  locale={locale}
>
  <div style={`--card-color: ${game.data.color}`}>
    <section class="game-hero">
      <div class="container">
        <div
          class={`game-hero-body ${game.data.category === "ios" ? "with-icon" : ""}`}
        >
          {
            game.data.category === "ios" && (
              <img
                class="game-hero-icon"
                src={heroIcon}
                alt={appIconAlt}
              />
            )
          }
          <div class="game-hero-text">
            <h1>{view.title}</h1>
            <p class="catch">{view.catch}</p>
            <div class="badges">
              {
                game.data.unityroomNo && (
                  <span class="badge badge-no">
                    {locale === "ja"
                      ? `${copy.project} ${game.data.unityroomNo}本目`
                      : `${copy.project} #${game.data.unityroomNo}`}
                  </span>
                )
              }
              <span class="badge">{view.genre}</span>
              {game.data.platforms.map((platform) => (
                <span class="badge">{platform}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container">
      <div class="game-detail">
        <div>
          <div
            class={`screenshots ${game.data.category === "ios" && game.data.screenshots.length > 0 ? "screenshots-phone" : ""}`}
          >
            {
              !(
                game.data.category === "ios" &&
                game.data.screenshots.length > 0
              ) && (
                <img
                  src={game.data.cover}
                  alt={mainImageAlt}
                />
              )
            }
            {
              game.data.screenshots.map((shot, index) => (
                <img
                  src={shot}
                  alt={screenshotAlt(index)}
                  loading="lazy"
                />
              ))
            }
          </div>
          {
            view.dialogue.length > 0 && (
              <Dialogue lines={view.dialogue} locale={locale} />
            )
          }
          <div class="prose">
            {
              translation ? (
                <>
                  <h2>{copy.features}</h2>
                  <ul>
                    {translation.features.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                  {
                    translation.controls &&
                      translation.controls.length > 0 && (
                        <>
                          <h2>{copy.howToPlay}</h2>
                          <ul>
                            {translation.controls.map((control) => (
                              <li>
                                {control.label && (
                                  <strong>{control.label}: </strong>
                                )}
                                {control.text}
                              </li>
                            ))}
                          </ul>
                        </>
                      )
                  }
                  {translation.notes?.map((note) => <p>{note}</p>)}
                </>
              ) : (
                <Content />
              )
            }
          </div>
          <a class="back-link" href={gameListHref}>{copy.back}</a>
        </div>

        <aside class="info-box">
          <dl>
            <dt>{copy.genre}</dt>
            <dd>{view.genre}</dd>
            <dt>{copy.platforms}</dt>
            <dd>{game.data.platforms.join(" / ")}</dd>
            <dt>{copy.releaseDate}</dt>
            <dd>{releaseLabel}</dd>
          </dl>
          {
            externalLinks.map((link) => (
              <a class="btn" href={link.url} target="_blank" rel="noopener">
                {link.label}
              </a>
            ))
          }
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
