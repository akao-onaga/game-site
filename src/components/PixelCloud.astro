---
interface Props {
  width?: number;
  style?: string;
}
const { width = 84, style } = Astro.props;
---

<svg
  width={width}
  height={width * (6 / 14)}
  viewBox="0 0 14 6"
  shape-rendering="crispEdges"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  style={style}
>
  <rect x="1" y="2" width="12" height="3" fill="#ffffff"></rect>
  <rect x="3" y="0" width="4" height="2" fill="#ffffff"></rect>
  <rect x="8" y="1" width="4" height="1" fill="#ffffff"></rect>
  <rect x="0" y="3" width="1" height="2" fill="#ffffff"></rect>
  <rect x="13" y="3" width="1" height="1" fill="#ffffff"></rect>
  <rect x="4" y="5" width="6" height="1" fill="#ffffff"></rect>
</svg>
