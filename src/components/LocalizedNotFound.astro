---
import { getLocalizedPath, type Locale } from "../i18n/config";
import { uiCopy } from "../i18n/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import PixelChara from "./PixelChara.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = uiCopy[locale].notFound;
---

<BaseLayout title={copy.title} locale={locale}>
  <section class="section" style="text-align: center; padding-bottom: 96px;">
    <div class="container">
      <p
        style="font-size: clamp(3rem, 10vw, 5rem); font-weight: 700; margin: 24px 0 0;"
      >
        404
      </p>
      <div style="display: flex; justify-content: center; padding: 8px 0 24px;">
        <PixelChara size={64} />
      </div>
      <p>{copy.message}</p>
      <p>
        <a class="back-link" href={getLocalizedPath("/", locale)}>
          {copy.back}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
